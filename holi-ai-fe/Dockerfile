FROM node:22-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install --legacy-peer-deps

COPY . .

ARG NEXT_PUBLIC_LOCAL_DB
ENV NEXT_PUBLIC_LOCAL_DB=$NEXT_PUBLIC_LOCAL_DB
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_GARMIN_DISABLED
ENV NEXT_PUBLIC_GARMIN_DISABLED=$NEXT_PUBLIC_GARMIN_DISABLED

RUN npm run build

EXPOSE 3000
CMD ["npm", "start"]
